# Local Supabase values are generated by:
#   bun run local:up
#   bun run local:env

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-via-bun-run-local-env
SUPABASE_SECRET_KEY=replace-via-bun-run-local-env

NEXT_PUBLIC_APP_URL=http://localhost:3000
PORTLESS_URL=http://localhost:3000

CLI_JWT_SECRET=straude-local-cli-secret
CRON_SECRET=straude-local-cron-secret
UNSUBSCRIBE_SECRET=straude-local-unsubscribe-secret

# Optional local overrides
RESEND_FROM_EMAIL=notifications@local.straude
ADMIN_USER_IDS=
RESEND_API_KEY=
ANTHROPIC_API_KEY=
FAL_API_KEY=
