{
  "name": "straude-monorepo",
  "private": true,
  "packageManager": "bun@1.3.3",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "dev:local": "bun run local:env && bun --cwd apps/web dev:plain",
    "build": "turbo build",
    "perf": "bun run --cwd apps/web perf",
    "perf:check": "bun run --cwd apps/web perf:check",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "local:up": "bunx supabase start",
    "local:down": "bunx supabase stop",
    "local:reset": "bunx supabase db reset --yes",
    "local:env": "bun --cwd apps/web ./scripts/write-local-env.mjs",
    "test": "turbo test",
    "local:seed": "bun --cwd apps/web ./scripts/seed-local-demo.mjs",
    "local:setup": "bun run local:up && bun run local:env && bun run local:seed"
  },
  "devDependencies": {
    "turbo": "^2.9.17",
    "typescript": "^5"
  },
  "dependencies": {
    "@21st-sdk/agent": "^0.0.15",
    "motion": "^12.34.3",
    "web": "^0.0.2"
  },
  "overrides": {
    "@21st-sdk/node": "0.0.9",
    "brace-expansion": "5.0.6",
    "dompurify": "3.4.8",
    "flatted": "3.4.2",
    "minimatch": "10.2.5",
    "picomatch": "4.0.4",
    "postcss": "8.5.15",
    "rollup": "4.61.1",
    "undici": "7.25.0",
    "vite": "8.0.16",
    "ws": "8.21.0"
  }
}
