{
  "name": "straude",
  "version": "0.1.25",
  "description": "CLI for pushing Claude Code usage stats to Straude",
  "main": "dist/index.js",
  "bin": {
    "straude": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "cd ../shared && bun run build && cd ../cli && tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build",
    "test": "vitest run"
  },
  "devDependencies": {
    "@straude/shared": "workspace:*",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@pppp606/ink-chart": "^0.2.4",
    "chalk": "^5.6.2",
    "ink": "^6.8.0",
    "posthog-node": "^5.29.1",
    "react": "^19.2.4"
  }
}
