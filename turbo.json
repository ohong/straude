{
  "$schema": "https://turbo.build/schema.json",
  "cacheDir": ".turbo/cache",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
        "SUPABASE_SECRET_KEY",
        "NEXT_PUBLIC_POSTHOG_KEY",
        "CLERK_SECRET_KEY",
        "CLI_JWT_SECRET",
        "ANTHROPIC_API_KEY",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "UNSUBSCRIBE_SECRET",
        "ADMIN_USER_IDS"
      ],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "cache": false,
      "dependsOn": ["^build"]
    }
  }
}
