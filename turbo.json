{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "app/**", "components/**", "lib/**", "types/**", "*.ts", "*.json", "*.css"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": ["NEXT_PUBLIC_SUPABASE_URL", "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": ["src/**", "app/**", "components/**", "lib/**", "types/**", "*.ts", "*.json"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "app/**", "components/**", "lib/**", "__tests__/**", "*.ts", "*.json"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "app/**", "components/**", "lib/**", "types/**", "*.ts", "*.json"]
    }
  }
}
